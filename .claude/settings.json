      "Bash(aws cloudwatch get-*)",
      "Bash(aws cloudwatch list-*)",
      "Bash(aws cloudwatch describe-*)",
      "Bash(aws iam get-*)",
      "Bash(aws iam list-*)",
      "Bash(aws lambda get-*)",
      "Bash(aws lambda list-*)",
      "Bash(aws bedrock list-*)",
      "Bash(aws bedrock get-*)",
      "Bash(aws athena get-*)",
