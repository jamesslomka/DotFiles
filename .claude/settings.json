{
  "env": {},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "showThinkingSummaries": true,
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "puppeteer",
    "context7"
  ],
  "cleanupPeriodDays": 9999,
  "permissions": {
          "allow": [
      "Write(**)",
      "Read(**)",
      "WebFetch",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
